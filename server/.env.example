# Supabase Credentials
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server Port
PORT=10000

# Server logs
SERVER_LOGS_ENABLED=true

# Feature flags (deprecated: server now runs a fixed authoritative mode)
# Kept only for backward compatibility in older deployments.
FF_DISABLE_LEGACY_SAVE_BLOB=true
FF_NORMALIZED_READS=true
FF_FREEZE_LEGACY_BLOB_FIELDS=false
FF_DUAL_WRITE_NORMALIZED=true
FF_DUAL_WRITE_STRICT=false

# Command gateway limits
COMMAND_RATE_WINDOW_MS=60000
COMMAND_RATE_MAX_REQUESTS=120
COMMAND_METRICS_LOG_INTERVAL_MS=60000
COMMAND_METRICS_RETENTION_MS=900000

# Ops alerts (optional)
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_MIN_INTERVAL_MS=60000
OPS_METRICS_KEY=

# Hard reset admin bootstrap (required only if DB_HARD_RESET=true)
DB_HARD_RESET=false
DB_HARD_RESET_CONFIRM=I_UNDERSTAND_DATA_LOSS
# Optional on Render: if empty, server uses RENDER_GIT_COMMIT/RENDER_DEPLOY_ID
DB_HARD_RESET_REQUEST_ID=
DB_RESET_ADMIN_EMAIL=admin@gmail.com
DB_RESET_ADMIN_PASSWORD=26335828JP
DB_RESET_ADMIN_USERNAME=Admin
