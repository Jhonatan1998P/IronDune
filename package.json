{
  "name": "iron-dune-monorepo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n \"API,WORKER,FRONT\" -c \"blue,green,magenta\" \"npm run api:dev\" \"npm run worker:dev\" \"npm run frontend:dev\"",
    "api:dev": "npm run dev -w apps/api",
    "worker:dev": "npm run dev -w apps/worker",
    "frontend:dev": "npm run dev -w apps/frontend",
    "build": "npm run build --workspaces --if-present",
    "api:start": "npm run start -w apps/api",
    "worker:start": "npm run start -w apps/worker",
    "test": "npm test --workspaces"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
